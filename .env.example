# ==========================================
# Configuration d'exemple pour le projet qwertz
# ==========================================
# Copier ce fichier en .env et remplir avec vos valeurs réelles
# 
# IMPORTANT: Ne JAMAIS commiter .env dans le repo
# Voir .gitignore pour les fichiers ignorés

# ==========================================
# Bitbucket
# ==========================================

# Token d'accès Bitbucket (OAuth ou PAT)
# Générer sur : https://bitbucket.company.net/account/settings/personal-bitbucket-auth-tokens
BITBUCKET_TOKEN=your_bitbucket_token_here

# URL de l'instance Bitbucket
BITBUCKET_URL=https://bitbucket.company.net

# Vérifier le certificat SSL Bitbucket (true/false)
BITBUCKET_VERIFY_SSL=true

# Chemin vers le bundle CA pour Bitbucket (optionnel si BITBUCKET_VERIFY_SSL=true)
# Laisser vide pour utiliser le certificat système
BITBUCKET_CA_BUNDLE=/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem

# ==========================================
# Bitbucket Webhook Security (IMPORTANT!)
# ==========================================

# Secret token pour sécuriser les webhooks Bitbucket (HMAC-SHA256)
# Générer sur Bitbucket : Repo Settings > Webhooks > Créer webhook > "Secret" field
# 
# ⚠️ IMPORTANT: 
# - Doit être identique entre .env et la config du webhook Bitbucket
# - Laisser vide pour DÉSACTIVER la vérification (mode développement seulement!)
# - En production: TOUJOURS définir un secret fort
BITBUCKET_WEBHOOK_SECRET=your_webhook_secret_here

# ==========================================
# BIG-IP
# ==========================================

# Identifiants de connexion à BIG-IP
BIGIP_USERNAME=admin
BIGIP_PASSWORD=your_bigip_password_here

# Vérifier le certificat SSL BIG-IP (true/false)
BIGIP_VERIFY_SSL=true

# Chemin vers le bundle CA pour BIG-IP (optionnel si BIGIP_VERIFY_SSL=true)
# Laisser vide pour utiliser le certificat système
BIGIP_CA_BUNDLE=/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem

# ==========================================
# Application
# ==========================================

# Chemin vers le fichier de configuration
CONFIG_PATH=config/config.yaml

# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# DEBUG: Endpoints de test disponibles via Swagger
# INFO: Logs normaux (production)
LOG_LEVEL=INFO

# ==========================================
# Optionnel - Proxy (si nécessaire)
# ==========================================

# HTTP_PROXY=http://proxy.company.net:8080
# HTTPS_PROXY=http://proxy.company.net:8080
# NO_PROXY=localhost,127.0.0.1,.company.net
