# ==========================================
# Configuration d'exemple pour le projet qwertz
# ==========================================
# Copier ce fichier en .env et remplir avec vos valeurs réelles
# 
# IMPORTANT: Ne JAMAIS commiter .env dans le repo
# Voir .gitignore pour les fichiers ignorés

# ==========================================
# Bitbucket
# ==========================================

# Token d'accès Bitbucket (OAuth ou PAT)
# Générer sur : https://bitbucket.company.net/account/settings/personal-bitbucket-auth-tokens
BITBUCKET_TOKEN=your_bitbucket_token_here

# URL de l'instance Bitbucket
BITBUCKET_URL=https://bitbucket.company.net

# ==========================================
# BIG-IP
# ==========================================

# Identifiants de connexion à BIG-IP
BIGIP_USERNAME=admin
BIGIP_PASSWORD=your_bigip_password_here

# ==========================================
# Application
# ==========================================

# Chemin vers le fichier de configuration
CONFIG_PATH=config/config.yaml

# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ==========================================
# Optionnel - Proxy (si nécessaire)
# ==========================================

# HTTP_PROXY=http://proxy.company.net:8080
# HTTPS_PROXY=http://proxy.company.net:8080
# NO_PROXY=localhost,127.0.0.1,.company.net
